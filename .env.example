DATA_ROOT=/data
ACTIVE_MODEL_PATH=/data/models/active/best.pt
CORS_ORIGINS=*

# External OCR/Qwen service used by /api/extract and /api/v1/extract-fields.
# If the OCR service runs on the Ubuntu host and backend runs in Docker, keep host.docker.internal.
OCR_FIVE_FIELDS_URL=http://host.docker.internal:5000/api/ocr-five-fields
OCR_FIVE_FIELDS_ENGINE=auto+qwen
OCR_FIVE_FIELDS_TIMEOUT=180
